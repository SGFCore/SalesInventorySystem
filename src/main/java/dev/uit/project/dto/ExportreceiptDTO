package dev.uit.project.dto;

import dev.uit.project.entity.*;
import java.time.Instant;
import java.time.LocalDate;
import java.math.BigDecimal;

public class ExportreceiptDTO {
    private Long id;
    private Long employeeId;
    private Boolean exporttype;
    private String reason;
    private String status;
    private LocalDate createddate;
    private Long warehouseId;
    public ExportreceiptDTO() {}
    public ExportreceiptDTO(Long id, Long employeeId, Boolean exporttype, String reason, String status,
                            LocalDate createddate, Long warehouseId) {
        this.id = id; this.employeeId = employeeId; this.exporttype = exporttype; this.reason = reason;
        this.status = status; this.createddate = createddate; this.warehouseId = warehouseId;
    }
    // Getters & Setters (viết tắt, bạn thêm đủ)
    public Long getId() { return id; }
    public void setId(Long id) { this.id = id; }
    public Long getEmployeeId() { return employeeId; }
    public void setEmployeeId(Long employeeId) { this.employeeId = employeeId; }
    public Boolean getExporttype() { return exporttype; }
    public void setExporttype(Boolean exporttype) { this.exporttype = exporttype; }
    public String getReason() { return reason; }
    public void setReason(String reason) { this.reason = reason; }
    public String getStatus() { return status; }
    public void setStatus(String status) { this.status = status; }
    public LocalDate getCreateddate() { return createddate; }
    public void setCreateddate(LocalDate createddate) { this.createddate = createddate; }
    public Long getWarehouseId() { return warehouseId; }
    public void setWarehouseId(Long warehouseId) { this.warehouseId = warehouseId; }

    public static ExportreceiptDTO fromEntity(Exportreceipt entity) {
        if (entity == null) return null;
        Long employeeId = entity.getEmployeeid() != null ? entity.getEmployeeid().getId() : null;
        Long warehouseId = entity.getWarehouseid() != null ? entity.getWarehouseid().getId() : null;
        return new ExportreceiptDTO(entity.getId(), employeeId, entity.getExporttype(),
                entity.getReason(), entity.getStatus(), entity.getCreateddate(), warehouseId);
    }
}