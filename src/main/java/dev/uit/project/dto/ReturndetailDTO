package dev.uit.project.dto;

import dev.uit.project.entity.*;
import java.time.Instant;
import java.time.LocalDate;
import java.math.BigDecimal;

public class ReturndetailDTO {
    private Long returnId;
    private Long productId;
    private Long quantity;
    private String qcStatus;
    private Long targetWarehouseId;
    private String actiontaken;
    public ReturndetailDTO() {}
    public ReturndetailDTO(Long returnId, Long productId, Long quantity, String qcStatus,
                           Long targetWarehouseId, String actiontaken) {
        this.returnId = returnId; this.productId = productId; this.quantity = quantity;
        this.qcStatus = qcStatus; this.targetWarehouseId = targetWarehouseId; this.actiontaken = actiontaken;
    }
    // Getters & Setters
    public Long getReturnId() { return returnId; }
    public void setReturnId(Long returnId) { this.returnId = returnId; }
    public Long getProductId() { return productId; }
    public void setProductId(Long productId) { this.productId = productId; }
    public Long getQuantity() { return quantity; }
    public void setQuantity(Long quantity) { this.quantity = quantity; }
    public String getQcStatus() { return qcStatus; }
    public void setQcStatus(String qcStatus) { this.qcStatus = qcStatus; }
    public Long getTargetWarehouseId() { return targetWarehouseId; }
    public void setTargetWarehouseId(Long targetWarehouseId) { this.targetWarehouseId = targetWarehouseId; }
    public String getActiontaken() { return actiontaken; }
    public void setActiontaken(String actiontaken) { this.actiontaken = actiontaken; }
    
    public static ReturndetailDTO fromEntity(Returndetail entity) {
        if (entity == null) return null;
        ReturndetailId id = entity.getId();
        Long targetId = entity.getTargetwarehouseid() != null ? entity.getTargetwarehouseid().getId() : null;
        return new ReturndetailDTO(id.getReturnid(), id.getProductid(), entity.getQuantity(),
                entity.getQcStatus(), targetId, entity.getActiontaken());
    }
}