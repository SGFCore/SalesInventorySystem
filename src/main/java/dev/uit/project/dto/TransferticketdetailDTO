package dev.uit.project.dto;

import dev.uit.project.entity.*;
import java.time.Instant;
import java.time.LocalDate;
import java.math.BigDecimal;

public class TransferticketdetailDTO {
    private Long transferId;
    private Long productId;
    private Long exportquantity;
    private Long receivequantity;
    private Long requestquantity;
    public TransferticketdetailDTO() {}
    public TransferticketdetailDTO(Long transferId, Long productId, Long exportquantity,
                                   Long receivequantity, Long requestquantity) {
        this.transferId = transferId; this.productId = productId; this.exportquantity = exportquantity;
        this.receivequantity = receivequantity; this.requestquantity = requestquantity;
    }
    // Getters & Setters
    public Long getTransferId() { return transferId; }
    public void setTransferId(Long transferId) { this.transferId = transferId; }
    public Long getProductId() { return productId; }
    public void setProductId(Long productId) { this.productId = productId; }
    public Long getExportquantity() { return exportquantity; }
    public void setExportquantity(Long exportquantity) { this.exportquantity = exportquantity; }
    public Long getReceivequantity() { return receivequantity; }
    public void setReceivequantity(Long receivequantity) { this.receivequantity = receivequantity; }
    public Long getRequestquantity() { return requestquantity; }
    public void setRequestquantity(Long requestquantity) { this.requestquantity = requestquantity; }
    public static TransferticketdetailDTO fromEntity(Transferticketdetail entity) {
        if (entity == null) return null;
        TransferticketdetailId id = entity.getId();
        return new TransferticketdetailDTO(id.getTransferid(), id.getProductid(),
                entity.getExportquantity(), entity.getReceivequantity(), entity.getRequestquantity());
    }
}