package dev.uit.project.dto;

import dev.uit.project.entity.*;
import java.time.Instant;
import java.time.LocalDate;
import java.math.BigDecimal;

public class ExportreceiptdetailDTO {
    private Long exportreceiptId;
    private Long productId;
    private Long quantity;
    public ExportreceiptdetailDTO() {}
    public ExportreceiptdetailDTO(Long exportreceiptId, Long productId, Long quantity) {
        this.exportreceiptId = exportreceiptId; this.productId = productId; this.quantity = quantity;
    }
    public Long getExportreceiptId() { return exportreceiptId; }
    public void setExportreceiptId(Long exportreceiptId) { this.exportreceiptId = exportreceiptId; }
    public Long getProductId() { return productId; }
    public void setProductId(Long productId) { this.productId = productId; }
    public Long getQuantity() { return quantity; }
    public void setQuantity(Long quantity) { this.quantity = quantity; }
    public static ExportreceiptdetailDTO fromEntity(Exportreceiptdetail entity) {
        if (entity == null) return null;
        ExportreceiptdetailId id = entity.getId();
        return new ExportreceiptdetailDTO(id.getExportreceiptid(), id.getProductid(), entity.getQuantity());
    }
}