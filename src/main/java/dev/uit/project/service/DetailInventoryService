package dev.uit.project.service;

import java.util.List;
import org.springframework.stereotype.Service;
import dev.uit.project.dto.DetailInventoryDTO;
import dev.uit.project.entity.DetailInventory;
import dev.uit.project.repository.DetailInventoryRepository;
import lombok.RequiredArgsConstructor;

@Service
@RequiredArgsConstructor
public class DetailInventoryService {
    
    private final DetailInventoryRepository detailInventoryRepository;
    
    /**
     * Lấy danh sách tất cả các chi tiết kho
     */
    public List<DetailInventoryDTO> list() {
        return detailInventoryRepository.findAll()
            .stream()
            .map(this::convertToDTO)
            .toList();
    }
    
    /**
     * Lấy thông tin chi tiết kho theo ID
     */
    public DetailInventoryDTO get(Long id) {
        return detailInventoryRepository.findById(id)
            .map(this::convertToDTO)
            .orElseThrow(() -> new RuntimeException("DetailInventory not found with id: " + id));
    }
    
    /**
     * Tạo mới một chi tiết kho
     */
    public DetailInventoryDTO create(DetailInventoryDTO detailInventoryDTO) {
        DetailInventory detailInventory = convertToEntity(detailInventoryDTO);
        DetailInventory savedDetailInventory = detailInventoryRepository.save(detailInventory);
        return convertToDTO(savedDetailInventory);
    }
    
    /**
     * Cập nhật thông tin chi tiết kho
     */
    public DetailInventoryDTO update(Long id, DetailInventoryDTO detailInventoryDTO) {
        DetailInventory existingDetailInventory = detailInventoryRepository.findById(id)
            .orElseThrow(() -> new RuntimeException("DetailInventory not found with id: " + id));
        
        existingDetailInventory.setName(detailInventoryDTO.getName());
        existingDetailInventory.setDescription(detailInventoryDTO.getDescription());
        
        DetailInventory updatedDetailInventory = detailInventoryRepository.save(existingDetailInventory);
        return convertToDTO(updatedDetailInventory);
    }
    
    /**
     * Xóa một chi tiết kho
     */
    public void delete(Long id) {
        if (!detailInventoryRepository.existsById(id)) {
            throw new RuntimeException("DetailInventory not found with id: " + id);
        }
        detailInventoryRepository.deleteById(id);
    }
    
    /**
     * Chuyển đổi Entity sang DTO
     */
    private DetailInventoryDTO convertToDTO(DetailInventory detailInventory) {
        return new DetailInventoryDTO(
            detailInventory.getId(),
            detailInventory.getName(),
            detailInventory.getDescription()
        );
    }
    
    /**
     * Chuyển đổi DTO sang Entity
     */
    private DetailInventory convertToEntity(DetailInventoryDTO detailInventoryDTO) {
        DetailInventory detailInventory = new DetailInventory();
        detailInventory.setName(detailInventoryDTO.getName());
        detailInventory.setDescription(detailInventoryDTO.getDescription());
        return detailInventory;
    }
}