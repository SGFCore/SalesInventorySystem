package dev.uit.project.service;

import java.util.List;
import org.springframework.stereotype.Service;
import dev.uit.project.dto.RequestDetailDTO;
import dev.uit.project.entity.RequestDetail;
import dev.uit.project.repository.RequestDetailRepository;
import lombok.RequiredArgsConstructor;

@Service
@RequiredArgsConstructor
public class RequestDetailService {
    
    private final RequestDetailRepository requestDetailRepository;
    
    /**
     * Lấy danh sách tất cả các chi tiết yêu cầu
     */
    public List<RequestDetailDTO> list() {
        return requestDetailRepository.findAll()
            .stream()
            .map(this::convertToDTO)
            .toList();
    }
    
    /**
     * Lấy thông tin chi tiết yêu cầu theo ID
     */
    public RequestDetailDTO get(Long id) {
        return requestDetailRepository.findById(id)
            .map(this::convertToDTO)
            .orElseThrow(() -> new RuntimeException("RequestDetail not found with id: " + id));
    }
    
    /**
     * Tạo mới một chi tiết yêu cầu
     */
    public RequestDetailDTO create(RequestDetailDTO requestDetailDTO) {
        RequestDetail requestDetail = convertToEntity(requestDetailDTO);
        RequestDetail savedRequestDetail = requestDetailRepository.save(requestDetail);
        return convertToDTO(savedRequestDetail);
    }
    
    /**
     * Cập nhật thông tin chi tiết yêu cầu
     */
    public RequestDetailDTO update(Long id, RequestDetailDTO requestDetailDTO) {
        RequestDetail existingRequestDetail = requestDetailRepository.findById(id)
            .orElseThrow(() -> new RuntimeException("RequestDetail not found with id: " + id));
        
        existingRequestDetail.setRequestdetailname(requestDetailDTO.getRequestdetailname());
        existingRequestDetail.setDiscount(requestDetailDTO.getDiscount());
        existingRequestDetail.setDetail(requestDetailDTO.getDetail());
        existingRequestDetail.setSpendinglimit(requestDetailDTO.getSpendinglimit());
        
        RequestDetail updatedRequestDetail = requestDetailRepository.save(existingRequestDetail);
        return convertToDTO(updatedRequestDetail);
    }
    
    /**
     * Xóa một chi tiết yêu cầu
     */
    public void delete(Long id) {
        if (!requestDetailRepository.existsById(id)) {
            throw new RuntimeException("RequestDetail not found with id: " + id);
        }
        requestDetailRepository.deleteById(id);
    }
    
    /**
     * Chuyển đổi Entity sang DTO
     */
    private RequestDetailDTO convertToDTO(RequestDetail requestDetail) {
        return new RequestDetailDTO(
            requestDetail.getId(),
            requestDetail.getRequestdetailname(),
            requestDetail.getDiscount(),
            requestDetail.getDetail(),
            requestDetail.getSpendinglimit()
        );
    }
    
    /**
     * Chuyển đổi DTO sang Entity
     */
    private RequestDetail convertToEntity(RequestDetailDTO requestDetailDTO) {
        RequestDetail requestDetail = new RequestDetail();
        requestDetail.setRequestdetailname(requestDetailDTO.getRequestdetailname());
        requestDetail.setDiscount(requestDetailDTO.getDiscount());
        requestDetail.setDetail(requestDetailDTO.getDetail());
        requestDetail.setSpendinglimit(requestDetailDTO.getSpendinglimit());
        return requestDetail;
    }
}