package dev.uit.project.service;

import java.util.List;
import org.springframework.stereotype.Service;
import dev.uit.project.dto.RequestFormDTO;
import dev.uit.project.entity.RequestForm;
import dev.uit.project.repository.RequestFormRepository;
import lombok.RequiredArgsConstructor;

@Service
@RequiredArgsConstructor
public class RequestFormService {
    
    private final RequestFormRepository requestFormRepository;
    
    /**
     * Lấy danh sách tất cả các phiếu yêu cầu
     */
    public List<RequestFormDTO> list() {
        return requestFormRepository.findAll()
            .stream()
            .map(this::convertToDTO)
            .toList();
    }
    
    /**
     * Lấy thông tin phiếu yêu cầu theo ID
     */
    public RequestFormDTO get(Long id) {
        return requestFormRepository.findById(id)
            .map(this::convertToDTO)
            .orElseThrow(() -> new RuntimeException("RequestForm not found with id: " + id));
    }
    
    /**
     * Tạo mới một phiếu yêu cầu
     */
    public RequestFormDTO create(RequestFormDTO requestFormDTO) {
        RequestForm requestForm = convertToEntity(requestFormDTO);
        RequestForm savedRequestForm = requestFormRepository.save(requestForm);
        return convertToDTO(savedRequestForm);
    }
    
    /**
     * Cập nhật thông tin phiếu yêu cầu
     */
    public RequestFormDTO update(Long id, RequestFormDTO requestFormDTO) {
        RequestForm existingRequestForm = requestFormRepository.findById(id)
            .orElseThrow(() -> new RuntimeException("RequestForm not found with id: " + id));
        
        existingRequestForm.setStatus(requestFormDTO.getStatus());
        existingRequestForm.setRequestDate(requestFormDTO.getRequestDate());
        existingRequestForm.setDescription(requestFormDTO.getDescription());
        
        RequestForm updatedRequestForm = requestFormRepository.save(existingRequestForm);
        return convertToDTO(updatedRequestForm);
    }
    
    /**
     * Xóa một phiếu yêu cầu
     */
    public void delete(Long id) {
        if (!requestFormRepository.existsById(id)) {
            throw new RuntimeException("RequestForm not found with id: " + id);
        }
        requestFormRepository.deleteById(id);
    }
    
    /**
     * Chuyển đổi Entity sang DTO
     */
    private RequestFormDTO convertToDTO(RequestForm requestForm) {
        return new RequestFormDTO(
            requestForm.getId(),
            requestForm.getStatus(),
            requestForm.getRequestDate(),
            requestForm.getDescription()
        );
    }
    
    /**
     * Chuyển đổi DTO sang Entity
     */
    private RequestForm convertToEntity(RequestFormDTO requestFormDTO) {
        RequestForm requestForm = new RequestForm();
        requestForm.setStatus(requestFormDTO.getStatus());
        requestForm.setRequestDate(requestFormDTO.getRequestDate());
        requestForm.setDescription(requestFormDTO.getDescription());
        return requestForm;
    }
}
