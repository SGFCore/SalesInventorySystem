package dev.uit.project.service;

import dev.uit.project.dto.PaymentDto;
import dev.uit.project.entity.Payment;
import dev.uit.project.repository.PaymentRepository;
import lombok.RequiredArgsConstructor;
import org.springframework.stereotype.Service;

import java.util.List;

@Service
@RequiredArgsConstructor
public class PaymentService {
    
    private final PaymentRepository paymentRepository;
    
    /**
     * Lấy danh sách tất cả các thanh toán
     */
    public List<PaymentDto> list() {
        return paymentRepository.findAll()
            .stream()
            .map(this::convertToDTO)
            .toList();
    }
    
    /**
     * Lấy thông tin thanh toán theo ID
     */
    public PaymentDto get(Long id) {
        return paymentRepository.findById(id)
            .map(this::convertToDTO)
            .orElseThrow(() -> new RuntimeException("Payment not found with id: " + id));
    }
    
    /**
     * Tạo mới một thanh toán
     */
    public PaymentDto create(PaymentDto paymentDto) {
        Payment payment = convertToEntity(paymentDto);
        Payment savedPayment = paymentRepository.save(payment);
        return convertToDTO(savedPayment);
    }
    
    /**
     * Cập nhật thông tin thanh toán
     */
    public PaymentDto update(Long id, PaymentDto paymentDto) {
        Payment existingPayment = paymentRepository.findById(id)
            .orElseThrow(() -> new RuntimeException("Payment not found with id: " + id));
        
        org.springframework.beans.BeanUtils.copyProperties(paymentDto, existingPayment, "id");
        
        Payment updatedPayment = paymentRepository.save(existingPayment);
        return convertToDTO(updatedPayment);
    }
    
    /**
     * Xóa một thanh toán
     */
    public void delete(Long id) {
        if (!paymentRepository.existsById(id)) {
            throw new RuntimeException("Payment not found with id: " + id);
        }
        paymentRepository.deleteById(id);
    }
    
    /**
     * Chuyển đổi Entity sang DTO
     */
    private PaymentDto convertToDTO(Payment payment) {
        PaymentDto dto = new PaymentDto();
        org.springframework.beans.BeanUtils.copyProperties(payment, dto);
        return dto;
    }
    
    /**
     * Chuyển đổi DTO sang Entity
     */
    private Payment convertToEntity(PaymentDto paymentDto) {
        Payment payment = new Payment();
        org.springframework.beans.BeanUtils.copyProperties(paymentDto, payment);
        return payment;
    }
}
